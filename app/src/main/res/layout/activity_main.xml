<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Legacy View Demo -->
    <FrameLayout
        android:id="@+id/viewDemoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Long press anywhere (View Demo)"
            android:textSize="16sp" />

        <io.github.gawwr4v.radialmenu.RadialMenuView
            android:id="@+id/radialMenu"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:rm_menuRadius="90dp"
            app:rm_iconSize="32dp" />
    </FrameLayout>

    <!-- Compose Demo -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Floating draggable controls panel -->
    <LinearLayout
        android:id="@+id/controlsPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/panel_background"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:background="@drawable/drag_handle" />

        <!-- Mode toggle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mode:"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btnShowViewDemo"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="12dp"
                android:text="View"
                android:textSize="11sp"
                style="?attr/materialButtonOutlinedStyle" />

            <Button
                android:id="@+id/btnShowComposeDemo"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="12dp"
                android:text="Compose"
                android:textSize="11sp"
                style="?attr/materialButtonOutlinedStyle" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTriggerHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="Long press anywhere to open"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp" />

        <!-- Item count + edge-hug row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvItemCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Items: 4"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

            <SeekBar
                android:id="@+id/seekItemCount"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:max="6"
                android:progress="2"
                android:layout_marginHorizontal="8dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchEdgeHug"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edge-Hug"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
